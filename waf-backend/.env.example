# 🛡️ Smart WAF Backend Configuration

# Server Environment (Set to 'true' for Render Free Tier to optimize CPU/Memory)
RENDER=false

# Port
PORT=4000

# Security (CRITICAL: Change this to a long random string in production)
# This is now REQUIRED for the backend to start.
JWT_SECRET=your_super_secure_random_hash_here

# Admin Default Credentials (Used for first-time seeding)
ADMIN_USERNAME=visaka
ADMIN_PASSWORD=visaka

# MongoDB Connection (Local or Atlas)
MONGO_URI=mongodb://localhost:27017/smart-waf

# Google Gemini API Key (Required for AI detection/analyst)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Email Alert System (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_RECIPIENT=admin-email@gmail.com

# Geo-IP Settings
BLOCKED_COUNTRIES=KP,RU
