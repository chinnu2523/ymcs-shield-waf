# 🛡️ Smart WAF Backend Configuration

# Server Port
PORT=4000

# MongoDB Connection (Local or Atlas)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/smart-waf
MONGO_URI=mongodb://localhost:27017/smart-waf

# Google Gemini API Key (Required for AI detection/analyst)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Email Alert System (Optional for demo)
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_RECIPIENT=admin-email@gmail.com

# Geo-IP Settings (Optional)
# List of country codes to block (e.g. CN,RU,KP)
BLOCKED_COUNTRIES=
